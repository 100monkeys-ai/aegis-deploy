{
  "id": null,
  "uid": "aegis-infrastructure",
  "title": "AEGIS Infrastructure",
  "tags": ["aegis", "infrastructure"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Service Up/Down",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"aegis-runtime\"}",
          "legendFormat": "AEGIS Runtime",
          "refId": "A"
        },
        {
          "expr": "up{job=\"postgres\"}",
          "legendFormat": "PostgreSQL",
          "refId": "B"
        },
        {
          "expr": "up{job=\"temporal\"}",
          "legendFormat": "Temporal",
          "refId": "C"
        },
        {
          "expr": "up{job=\"keycloak\"}",
          "legendFormat": "Keycloak",
          "refId": "D"
        },
        {
          "expr": "up{job=\"openbao\"}",
          "legendFormat": "OpenBao",
          "refId": "E"
        },
        {
          "expr": "up{job=\"seaweedfs-master\"}",
          "legendFormat": "SeaweedFS Master",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "Up", "color": "green" },
                "0": { "text": "Down", "color": "red" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "title": "PostgreSQL",
      "type": "row",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 3,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "x": 0, "y": 5, "w": 6, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "title": "Transactions/s",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 5, "w": 9, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"aegis\"}[5m]) + rate(pg_stat_database_xact_rollback{datname=\"aegis\"}[5m])",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "x": 15, "y": 5, "w": 9, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname=\"aegis\"} / (pg_stat_database_blks_hit{datname=\"aegis\"} + pg_stat_database_blks_read{datname=\"aegis\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "title": "Keycloak",
      "type": "row",
      "gridPos": { "x": 0, "y": 11, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "title": "Login Events",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(keycloak_login_attempts_total[5m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 8,
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "keycloak_sessions_count",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 9,
      "title": "Request Duration P95",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(keycloak_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 10,
      "title": "SeaweedFS",
      "type": "row",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "title": "Volume Count",
      "type": "stat",
      "gridPos": { "x": 0, "y": 19, "w": 6, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "seaweedfs_master_volumes_total",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 12,
      "title": "Disk Used",
      "type": "stat",
      "gridPos": { "x": 6, "y": 19, "w": 6, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "seaweedfs_volume_disk_used_bytes",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 13,
      "title": "Read/Write Ops",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(seaweedfs_filer_request_total[5m])",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 14,
      "title": "Temporal",
      "type": "row",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 15,
      "title": "Workflows Started",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 8, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(temporal_workflow_started_total[5m]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 16,
      "title": "Workflows Completed",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 26, "w": 8, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(temporal_workflow_completed_total[5m]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 17,
      "title": "Workflow Failures",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 26, "w": 8, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(temporal_workflow_failed_total[5m]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    }
  ]
}
