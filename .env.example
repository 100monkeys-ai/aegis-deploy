# =============================================================================
# AEGIS Platform Deployment — Environment Configuration
# =============================================================================
# Copy to .env and fill in required values before deploying.
# =============================================================================

# --- Deployment Root ---
# Absolute path to the aegis-deploy checkout.
AEGIS_ROOT=

# --- Registry ---
# GitHub Personal Access Token (PAT) with read:packages scope.
# Required to pull images from ghcr.io/100monkeys-ai.
# Create one at: https://github.com/settings/tokens/new?scopes=read:packages
GHCR_USERNAME=
GHCR_TOKEN=

# --- Image Tags ---
AEGIS_IMAGE_TAG=latest

# --- PostgreSQL ---
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis
# Database host — defaults to aegis-database pod; override for external/managed DB
AEGIS_DB_HOST=aegis-database

# --- AEGIS Runtime ---
RUST_LOG=info,aegis_orchestrator=debug
AEGIS_CONTAINER_NETWORK=aegis-network
AEGIS_ORCHESTRATOR_URL=http://aegis-core:8088
AEGIS_KEEP_CONTAINER=false
AEGIS_CLUSTER_PORT=50056
AEGIS_OTLP_ENDPOINT=http://jaeger:4317

# --- Monitoring ---
GRAFANA_ADMIN_PASSWORD=changeme
# Root path for Podman container logs (rootless default)
PODMAN_LOG_ROOT=${HOME}/.local/share/containers/storage/overlay-containers

# --- SMCP ---
# Auto-populated by `make generate-keys` — do not set manually.
#AEGIS_SMCP_PRIVATE_KEY=
# Path to SMCP key files
SMCP_PRIVATE_KEY_PATH=./generated/smcp/private.pem
SMCP_PUBLIC_KEY_PATH=./generated/smcp/public.pem

# --- LLM Provider ---
# API key for your LLM provider. Used by AEGIS Runtime for agent execution.
# Supports: OpenAI, Anthropic, Google Gemini, Ollama (local)
# Configure provider details in podman/pods/core/aegis-config.yaml
LLM_API_KEY=

# --- Keycloak IAM ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_REALM=aegis-system
KEYCLOAK_HOST=http://aegis-iam:8180
# Public-facing Keycloak URL (used in browser redirects for OIDC login)
KEYCLOAK_PUBLIC_URL=https://auth.example.com

# --- OpenBao Secrets ---
# Auto-populated by `make bootstrap-secrets` — do not set manually.
OPENBAO_ROLE_ID=
OPENBAO_SECRET_ID=

# --- Edge Proxy (production) ---
CLOUDFLARE_API_TOKEN=
DOMAIN_KEYCLOAK=auth.localhost
DOMAIN_SMCP=smcp.localhost
DOMAIN_TEMPORAL=temporal.localhost
DOMAIN_JAEGER=jaeger.localhost
DOMAIN_GRAFANA=grafana.localhost
DOMAIN_PROMETHEUS=prometheus.localhost
DOMAIN_SECRETS=secrets.localhost
DOMAIN_API=api.localhost

# --- Podman-specific ---
# Rootless Podman socket — path is user-scoped.
# Format: /run/user/<UID>/podman/podman.sock
CONTAINER_SOCK=/run/user/1000/podman/podman.sock
# NFS host — for Podman on Linux, use the gateway IP or host.containers.internal
AEGIS_NFS_HOST=host.containers.internal
