# =============================================================================
# AEGIS Platform Deployment — Environment Configuration
# =============================================================================
# Copy to .env and fill in required values before deploying.
# =============================================================================

# --- Deployment Root ---
# Absolute path to the aegis-deploy checkout.
AEGIS_ROOT=

# --- Registry ---
# GitHub Personal Access Token (PAT) with read:packages scope.
# Required to pull images from ghcr.io/100monkeys-ai.
# Create one at: https://github.com/settings/tokens/new?scopes=read:packages
GHCR_USERNAME=
GHCR_TOKEN=

# --- Image Tags ---
AEGIS_IMAGE_TAG=latest

# --- PostgreSQL ---
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis
# Database host — defaults to aegis-database pod; override for external/managed DB
AEGIS_DB_HOST=aegis-database
# PgBouncer port (transaction mode) — used by services for connection pooling
PGBOUNCER_PORT=5433

# --- AEGIS Runtime ---
RUST_LOG=info,aegis_orchestrator=debug
AEGIS_CONTAINER_NETWORK=aegis-network
AEGIS_ORCHESTRATOR_URL=http://aegis-core:8088
AEGIS_KEEP_CONTAINER=false
# Force re-deploy all built-in agents/workflows on startup (flush stale definitions after an upgrade).
# Toggle to true, restart the container, then set back to false.
AEGIS_FORCE_DEPLOY_BUILTINS=false
AEGIS_CLUSTER_PORT=50056
AEGIS_OTLP_ENDPOINT=http://jaeger:4317

# --- Monitoring ---
GRAFANA_ADMIN_PASSWORD=changeme
# Root path for Podman container logs (rootless default)
PODMAN_LOG_ROOT=${HOME}/.local/share/containers/storage/overlay-containers

# --- SEAL ---
# Internal URL for the SEAL gateway — used by the orchestrator to pre-create sessions.
AEGIS_SEAL_GATEWAY_URL=http://aegis-seal-gateway:8089
# Auto-populated by `make generate-keys` — do not set manually.
#AEGIS_SEAL_PRIVATE_KEY=
# Path to SEAL key files
SEAL_PRIVATE_KEY_PATH=./generated/seal/private.pem
SEAL_PUBLIC_KEY_PATH=./generated/seal/public.pem

# --- AEGIS Cortex (Learning & Memory) ---
# gRPC URL for cortex service (used by runtime to connect)
CORTEX_GRPC_URL=http://aegis-cortex:50052

# --- LLM Provider ---
# Google Gemini API key — used by AEGIS Runtime for agent execution.
# Create at: https://aistudio.google.com/app/apikey
ZARU_LLM_API_KEY=

# --- Keycloak IAM ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_REALM=zaru-consumer
KEYCLOAK_HOST=http://aegis-iam:8180
# Public-facing Keycloak URL (used in browser redirects for OIDC login)
KEYCLOAK_PUBLIC_URL=https://auth.example.com
# Derived from KEYCLOAK_PUBLIC_URL + KEYCLOAK_REALM — update both if either changes
KEYCLOAK_ISSUER_URL=https://auth.example.com/realms/zaru-consumer
KEYCLOAK_JWKS_URI=https://auth.example.com/realms/zaru-consumer/protocol/openid-connect/certs

# Temporal worker service account (aegis-system realm)
KEYCLOAK_SYSTEM_ISSUER_URL=https://auth.example.com/realms/aegis-system
KEYCLOAK_SYSTEM_JWKS_URI=https://auth.example.com/realms/aegis-system/protocol/openid-connect/certs
KEYCLOAK_TEMPORAL_WORKER_SECRET=
# SSO session idle timeout in seconds (default: 1800 = 30 min)
KEYCLOAK_SESSION_IDLE_TIMEOUT=1800

# --- Postmark (Transactional Email) ---
# Used by Keycloak for registration verification, password reset, etc.
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=noreply@myzaru.com

# --- OpenBao Secrets ---
# Auto-populated by `make bootstrap-secrets` — do not set manually.
OPENBAO_ROLE_ID=
OPENBAO_SECRET_ID=

# --- Orchestrator Proxy ---
# Bearer token for server-side proxy calls to the orchestrator.
# Leave empty if the orchestrator runs without IAM auth (development default).
AEGIS_API_TOKEN=

# --- Edge Proxy (production) ---
CLOUDFLARE_API_TOKEN=
DOMAIN_KEYCLOAK=auth.example.com
DOMAIN_SEAL=seal.example.com
DOMAIN_TEMPORAL=temporal.example.com
DOMAIN_JAEGER=jaeger.example.com
DOMAIN_GRAFANA=grafana.example.com
DOMAIN_PROMETHEUS=prometheus.example.com
DOMAIN_SECRETS=secrets.example.com
DOMAIN_API=api.example.com
DOMAIN_APP=app.example.com
DOMAIN_MCP=mcp.example.com
DOMAIN_PORTAINER=portainer.example.com

# --- Podman-specific ---
# Rootless Podman socket — path is user-scoped.
# Format: /run/user/<UID>/podman/podman.sock
CONTAINER_SOCK=/run/user/1000/podman/podman.sock
# NFS host — for Podman on Linux, use the gateway IP or host.containers.internal
AEGIS_NFS_HOST=host.containers.internal
